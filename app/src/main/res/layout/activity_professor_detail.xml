<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Indigo Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#3D3580"
            android:paddingTop="52dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:gravity="center_horizontal">

            <!-- Yellow Avatar Circle -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_avatar_yellow">

                <TextView
                    android:id="@+id/professorInitialText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="@color/indigo_primary" />
            </FrameLayout>

            <!-- Professor Name -->
            <TextView
                android:id="@+id/detailProfessorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center" />

            <!-- Department -->
            <TextView
                android:id="@+id/detailProfessorDepartment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#C9C4E8"
                android:gravity="center" />

            <!-- PROFESSOR Badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="PROFESSOR"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/indigo_primary"
                android:background="@drawable/bg_logo_yellow"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />

        </LinearLayout>

        <!-- Content Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- OFFICE HOURS Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_action_indigo_light"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFFICE HOURS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/indigo_primary"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/detailOfficeHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- LOCATION Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_action_yellow_light"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCATION"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#B38E00"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/detailLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- COURSES Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COURSES"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <!-- Course pills injected here at runtime -->
            <LinearLayout
                android:id="@+id/coursePillsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp" />

            <!-- EMAIL PROFESSOR Button -->
            <TextView
                android:id="@+id/emailProfessorButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="EMAIL PROFESSOR"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/indigo_primary"
                android:gravity="center"
                android:background="@drawable/bg_yellow_button"
                android:letterSpacing="0.06" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
