<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Indigo Header with avatar and rating -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/indigo_primary"
            android:gravity="center_horizontal"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Yellow avatar circle -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_avatar_yellow">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="T"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/indigo_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/profileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/profileType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#C9C4E8"
                android:layout_marginTop="4dp" />

            <!-- Rating row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★ ★ ★ ★ ★"
                    android:textSize="14sp"
                    android:textColor="@color/yellow_accent"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/profileRatingSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 (0 reviews)"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Content area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SUBJECTS card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_bordered"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUBJECTS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/profileSubjects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- COURSES card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_bordered"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COURSES"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/profileCourses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- AVAILABILITY card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_bordered"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AVAILABILITY"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/profileAvailability"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- RATE card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_bordered"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RATE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/profileRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/paid_color" />

            </LinearLayout>

            <!-- Yellow Request Session Button -->
            <Button
                android:id="@+id/requestSessionButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Request Session"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_yellow_button"
                android:stateListAnimator="@null" />

            <!-- Rate this Tutor Button -->
            <TextView
                android:id="@+id/rateButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Rate this Tutor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_yellow_button"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:layout_marginTop="12dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
