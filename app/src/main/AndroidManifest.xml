<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".AcademicHubApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AcademicHub">
        <activity
            android:name=".ui.student.BrowseSessionsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.tutor.PostSessionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.student.MyRequestsActivity"
            android:exported="false" /> <!-- Login Screen - opens first -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Sign Up Screen -->
        <activity
            android:name=".ui.SignUpActivity"
            android:exported="false" /> <!-- Student Dashboard -->
        <activity
            android:name=".ui.student.StudentDashboardActivity"
            android:exported="false" /> <!-- Tutor List -->
        <activity
            android:name=".ui.student.TutorListActivity"
            android:exported="false" /> <!-- Tutor Profile -->
        <activity
            android:name=".ui.student.TutorProfileActivity"
            android:exported="false" /> <!-- Favorite Tutors -->
        <activity
            android:name=".ui.student.FavoriteTutorsActivity"
            android:exported="false" /> <!-- Session Request -->
        <activity
            android:name=".ui.student.SessionRequestActivity"
            android:exported="false" /> <!-- Tutor Dashboard -->
        <activity
            android:name=".ui.tutor.TutorDashboardActivity"
            android:exported="false" /> <!-- Professor Directory -->
        <activity
            android:name=".ui.professor.ProfessorDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.professor.ProfessorDirectoryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.professor.ProfessorDetailActivity"
            android:exported="false" /> <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
    </application>

</manifest>